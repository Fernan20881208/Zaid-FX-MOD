{
  "geode": "5.7.1",
  "gd": {
    "android": "2.2081"
  },
  "id": "zaid.zaid-fx-mod",
  "name": "Zaid-FX-MOD",
  "version": "v0.3.0",
  "developer": "Zaid",
  "description": "Configurable color grading and lightweight screen effects for Geometry Dash on Android.",
  "links": {
    "source": "https://github.com/Fernan20881208/Zaid-FX-MOD"
  },
  "issues": {
    "info": "Include your device, GPU, Android, Geometry Dash and Geode versions, plus the latest crash log.",
    "url": "https://github.com/Fernan20881208/Zaid-FX-MOD/issues"
  },
  "tags": [
    "customization",
    "enhancement",
    "offline",
    "universal"
  ],
  "resources": {
    "files": [
      "resources/shaders/*.vert",
      "resources/shaders/*.frag"
    ]
  },
  "settings": {
    "general-title": {
      "type": "title",
      "name": "Zaid FX"
    },
    "enabled": {
      "type": "bool",
      "name": "Enable effects",
      "description": "Apply the selected effects to the final game frame.",
      "default": false
    },
    "preset": {
      "type": "string",
      "name": "Preset",
      "description": "Choose a starting profile. Changing a slider switches the profile to Custom.",
      "default": "Default",
      "one-of": ["Custom", "Default", "Cinematic", "Vibrant", "Dark", "Retro", "Glow"],
      "enable-if": "enabled"
    },
    "effect-intensity": {
      "type": "float",
      "name": "Effect intensity",
      "description": "Blend between the original frame and the processed frame.",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "brightness": {
      "type": "float",
      "name": "Brightness",
      "default": 0.0,
      "min": -1.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "exposure": {
      "type": "float",
      "name": "Exposure",
      "description": "Adjust exposure in stops.",
      "default": 0.0,
      "min": -2.0,
      "max": 2.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "contrast": {
      "type": "float",
      "name": "Contrast",
      "default": 1.0,
      "min": 0.25,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "saturation": {
      "type": "float",
      "name": "Saturation",
      "description": "Use 0 for grayscale and 1 for the original saturation.",
      "default": 1.0,
      "min": 0.0,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "gamma": {
      "type": "float",
      "name": "Gamma",
      "default": 1.0,
      "min": 0.25,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "bloom": {
      "type": "float",
      "name": "Highlight glow",
      "description": "Add a small single-pass glow around bright areas.",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "vignette": {
      "type": "float",
      "name": "Vignette",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "sharpen": {
      "type": "float",
      "name": "Sharpen",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "chromatic-aberration": {
      "type": "float",
      "name": "Chromatic aberration",
      "description": "Offset the red and blue channels near the screen edges.",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "tonemapping": {
      "type": "float",
      "name": "Tone mapping",
      "description": "Blend toward an ACES-style tone curve.",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    }
  }
}
