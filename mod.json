{
  "geode": "5.7.1",
  "gd": {
    "android": "2.2081"
  },
  "id": "zaid.zaid-fx-mod",
  "name": "Zaid-FX-MOD",
  "version": "v0.2.1",
  "developer": "Zaid Navarro",
  "description": "Final-frame Android post-processing, live presets and visual filters for Geometry Dash using Geode.",
  "links": {
    "source": "https://github.com/Fernan20881208/Zaid-FX-MOD",
    "homepage": "https://www.instagram.com/Zaid.nvr/",
    "community": "https://wa.me/523345158805"
  },
  "issues": {
    "info": "Report Android device, GPU, Geode version and attach the latest crash log. Email: zaidnavarrosaucedo@gmail.com",
    "url": "https://github.com/Fernan20881208/Zaid-FX-MOD/issues"
  },
  "dependencies": {
    "geode.node-ids": ">=v1.23.3"
  },
  "tags": [
    "customization",
    "enhancement",
    "performance",
    "offline"
  ],
  "resources": {
    "files": [
      "resources/shaders/*.vert",
      "resources/shaders/*.frag"
    ],
    "sprites": [
      "resources/ZaidFXLogo.png"
    ]
  },
  "settings": {
    "general-title": {
      "type": "title",
      "name": "Zaid FX"
    },
    "enabled": {
      "type": "bool",
      "name": "Enable effects",
      "description": "Processes the final framebuffer immediately before Android presents it.",
      "default": false
    },
    "preset": {
      "type": "string",
      "name": "Preset",
      "description": "Selecting a preset immediately updates every slider, the active renderer state and all shader uniforms. Manual slider changes switch this to Custom.",
      "default": "Default",
      "one-of": ["Custom", "Default", "Cinematic", "Vibrant", "Dark", "Retro", "RTX"],
      "enable-if": "enabled"
    },
    "effect-intensity": {
      "type": "float",
      "name": "Effect intensity",
      "description": "Blends between the original frame (0) and the processed frame (1).",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "brightness": {
      "type": "float",
      "name": "Brightness",
      "default": 0.0,
      "min": -1.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "exposure": {
      "type": "float",
      "name": "Exposure",
      "description": "Exposure in stops, applied with exp2 in the shader.",
      "default": 0.0,
      "min": -2.0,
      "max": 2.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "contrast": {
      "type": "float",
      "name": "Contrast",
      "default": 1.0,
      "min": 0.25,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "saturation": {
      "type": "float",
      "name": "Saturation",
      "description": "0 is grayscale, 1 is original saturation and values above 1 increase color intensity.",
      "default": 1.0,
      "min": 0.0,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "gamma": {
      "type": "float",
      "name": "Gamma",
      "default": 1.0,
      "min": 0.25,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "bloom": {
      "type": "float",
      "name": "Bloom",
      "description": "Adds a lightweight highlight glow in the final fullscreen pass.",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "vignette": {
      "type": "float",
      "name": "Vignette",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "sharpen": {
      "type": "float",
      "name": "Sharpen",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "chromatic-aberration": {
      "type": "float",
      "name": "Chromatic aberration",
      "description": "Separates RGB sampling slightly toward the screen edges.",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "tonemapping": {
      "type": "float",
      "name": "Tonemapping",
      "description": "Blends toward an ACES-style tone-mapped result.",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "diagnostics-title": {
      "type": "title",
      "name": "Diagnostics"
    },
    "debug-red-screen": {
      "type": "bool",
      "name": "Red framebuffer test",
      "description": "Temporarily forces the final fullscreen quad to solid red.",
      "default": false,
      "enable-if": "enabled"
    },
    "debug-logging": {
      "type": "bool",
      "name": "Shader and preset debug logging",
      "description": "Logs preset selection, internal IDs, loaded values, slider assignments, uniforms and final shader updates.",
      "default": true
    }
  }
}
