{
  "geode": "5.7.1",
  "gd": {
    "android": "2.2081"
  },
  "id": "zaid.zaid-fx-mod",
  "name": "Zaid-FX-MOD",
  "version": "v0.2.0",
  "developer": "Zaid Navarro",
  "description": "Live Android post-processing and visual filters for Geometry Dash using Geode.",
  "links": {
    "source": "https://github.com/Fernan20881208/Zaid-FX-MOD",
    "homepage": "https://www.instagram.com/Zaid.nvr/",
    "community": "https://wa.me/523345158805"
  },
  "issues": {
    "info": "Report Android device, GPU, Geode version and attach the latest crash log. Email: zaidnavarrosaucedo@gmail.com",
    "url": "https://github.com/Fernan20881208/Zaid-FX-MOD/issues"
  },
  "dependencies": {
    "geode.node-ids": ">=v1.23.3"
  },
  "tags": [
    "customization",
    "enhancement",
    "performance",
    "offline"
  ],
  "resources": {
    "files": [
      "resources/shaders/*.vert",
      "resources/shaders/*.frag"
    ]
  },
  "settings": {
    "general-title": {
      "type": "title",
      "name": "Zaid FX"
    },
    "enabled": {
      "type": "bool",
      "name": "Enable effects",
      "description": "Renders the complete game through the live post-processing pipeline.",
      "default": false
    },
    "preset": {
      "type": "string",
      "name": "Preset",
      "description": "Selecting a preset writes its values into the real sliders. Moving a slider changes this to Custom.",
      "default": "Clean",
      "one-of": ["Custom", "Clean", "OLED", "Vibrant", "Cinematic", "RTX Fake", "Competitive"],
      "enable-if": "enabled"
    },
    "effect-intensity": {
      "type": "float",
      "name": "Effect intensity",
      "description": "Blends between the original frame (0) and the processed frame (1).",
      "default": 1.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "brightness": {
      "type": "float",
      "name": "Brightness",
      "description": "Adds or removes brightness after exposure. Values are sent directly as -1.0 to 1.0.",
      "default": 0.0,
      "min": -1.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "exposure": {
      "type": "float",
      "name": "Exposure",
      "description": "Exposure in stops, applied with exp2 in the shader.",
      "default": 0.0,
      "min": -2.0,
      "max": 2.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "contrast": {
      "type": "float",
      "name": "Contrast",
      "default": 1.0,
      "min": 0.25,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "saturation": {
      "type": "float",
      "name": "Saturation",
      "description": "0 is grayscale, 1 is original saturation and values above 1 increase color intensity.",
      "default": 1.0,
      "min": 0.0,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "gamma": {
      "type": "float",
      "name": "Gamma",
      "default": 1.0,
      "min": 0.25,
      "max": 3.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "vignette": {
      "type": "float",
      "name": "Vignette",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "sharpen": {
      "type": "float",
      "name": "Sharpen",
      "default": 0.0,
      "min": 0.0,
      "max": 1.0,
      "control": { "slider": true, "slider-step": 0.05, "input": true },
      "enable-if": "enabled"
    },
    "diagnostics-title": {
      "type": "title",
      "name": "Diagnostics"
    },
    "debug-logging": {
      "type": "bool",
      "name": "Shader debug logging",
      "description": "Temporarily logs slider values, renderer values, uniform updates and final frame values.",
      "default": true
    }
  }
}
